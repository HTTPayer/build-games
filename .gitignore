# =============================================================================
# SECRETS — never commit real credentials
# =============================================================================

# All .env files are secret by default
.env
.env.*

# Allow sample / example templates
!.env.sample
!.env.example
!**/.env.sample
!**/.env.example

# Explicit key/cert files
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# =============================================================================
# FOUNDRY (contracts/)
# =============================================================================

contracts/out/
contracts/cache/

# Keep the latest live broadcast (used as address source of truth by scripts)
contracts/broadcast/
!contracts/broadcast/
!contracts/broadcast/DeployAll.s.sol/
!contracts/broadcast/DeployAll.s.sol/43113/
!contracts/broadcast/DeployAll.s.sol/43113/run-latest.json
!contracts/broadcast/DeployWrappedRevenueShare.s.sol/
!contracts/broadcast/DeployWrappedRevenueShare.s.sol/43113/
!contracts/broadcast/DeployWrappedRevenueShare.s.sol/43113/run-latest.json

# Drop local anvil + dry-run artifacts
contracts/broadcast/*/31337/
contracts/broadcast/**/dry-run/

# Foundry dependencies (installed via forge install / submodules)
contracts/lib/

# =============================================================================
# PYTHON (contracts/scripts/)
# =============================================================================

**/.venv/
**/__pycache__/
contracts/composed.egg-info/
contracts/*.egg-info/
*.pyc
*.pyo
*.egg-info/
.python-version

# Watcher runtime state (block cursors, processed IDs — env-specific)
contracts/scripts/cre_watcher_state.json
contracts/scripts/challenger_watcher_state.json

# Analytics runtime state
contracts/scripts/analytics_state.json
analytics/analytics_state.json
analytics/analytics.db

# Challenger watcher state
challenger_watcher/challenger_watcher_state.json

# SQLite databases (runtime artifacts)
*.db

# =============================================================================
# NODE / TYPESCRIPT
# =============================================================================

**/node_modules/
**/dist/
**/*.tsbuildinfo

# =============================================================================
# CRE workflow temp artifacts
# =============================================================================

cre/integrity-workflow/.workflow-temp-*.ts
cre/integrity-workflow/tmp.js
cre/integrity-workflow/tmp.wasm

# CRE project config (contains secrets — use *.sample.yaml as template)
cre/project.yaml
cre/integrity-workflow/workflow.yaml

# =============================================================================
# OS / EDITOR
# =============================================================================

.DS_Store
Thumbs.db
desktop.ini
*.log
*.swp
*.swo
.idea/
.vscode/
*.suo
*.user

# =============================================================================
# CONFIG FILES WITH SECRETS
# =============================================================================

*.yaml
*.yml
!*.sample.yaml
!*.sample.yml

# =============================================================================
# MISC
# =============================================================================

notes.txt
**/notes.txt
frontend-hackathon-avalanche/
