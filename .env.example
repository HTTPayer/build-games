# ================================================================
# DEPLOYMENT CONFIGURATION
# ================================================================

# Admin & Treasury Addresses
ADMIN=0x0000000000000000000000000000000000000000
TREASURY=0x0000000000000000000000000000000000000000

# Deployment Private Key (NEVER commit .env with real key)
PRIVATE_KEY=your_private_key_here

# ================================================================
# NETWORK CONFIGURATION
# ================================================================

# Avalanche Fuji Testnet
AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_FUJI_CHAIN_ID=43113

# Avalanche Mainnet (for production)
AVALANCHE_MAINNET_RPC_URL=https://api.avax.network/ext/bc/C/rpc
AVALANCHE_MAINNET_CHAIN_ID=43114

# ================================================================
# TOKEN ADDRESSES
# ================================================================

# Deploy MockUSDC + MockUSDCSwap for testnet (true/false)
# When true:  MockUSDC is used for all protocol contracts.
#             USDC below is treated as the real testnet USDC for the swap contract.
# When false: USDC below is used directly. No mock contracts deployed.
DEPLOY_MOCK_USDC=true

# USDC on Avalanche Fuji (real — used as realUSDC in MockUSDCSwap when DEPLOY_MOCK_USDC=true)
USDC=0x5425890298aed601595a70AB815c96711a31Bc65

# USDC on Avalanche Mainnet (set DEPLOY_MOCK_USDC=false for mainnet)
# USDC=0xB97EF9Ef8734C71904D8002F8b6Bc66Dd9c48a6E

# ================================================================
# CHAINLINK CONFIGURATION
# ================================================================

# Chainlink Functions Router (Avalanche Fuji)
CL_ROUTER=0xA9d587a00A31A52Ed70D6026794a8FC5E2F5dCb0

# Chainlink DON ID (Functions)
CL_DON_ID=0x66756e2d6176616c616e6368652d66756a692d31000000000000000000000000

# Chainlink Subscription ID (you'll get this after creating subscription)
CL_SUB_ID=0

# ================================================================
# PROTOCOL PARAMETERS
# ================================================================

# Minimum stake required (in USDC, 6 decimals)
# Example: 1000e6 = 1,000 USDC
MINIMUM_STAKE=1000000000

# Challenge fee (in USDC, 6 decimals)
# Example: 100e6 = 100 USDC
CHALLENGE_FEE=100000000

# Slash percentage (in basis points)
# Example: 2000 = 20%
SLASH_BP=2000

# Protocol treasury cut from slashing (in basis points)
# Example: 1000 = 10%
PROTOCOL_SLASH_BP=1000

# Withdrawal cooldown (in seconds)
# Example: 604800 = 7 days
WITHDRAW_COOLDOWN=604800

# ================================================================
# REVENUE LAYER CONFIGURATION
# ================================================================

# Treasury basis points for revenue sharing
# Protocol cap: MAX_PROTOCOL_BP = 300 (3%). Enforced in APIRegistryFactory.
# Example: 200 = 2% to protocol treasury, remainder split between provider treasury and vault
TREASURY_BP=200

# ================================================================
# VERIFICATION
# ================================================================

# Snowtrace API Key (for contract verification)
SNOWTRACE_API_KEY=your_api_key_here

# Etherscan API Key (alternative, some tools use this variable name)
ETHERSCAN_API_KEY=your_api_key_here
